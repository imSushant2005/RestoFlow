{
  "name": "bhojflow-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @bhojflow/api dev",
    "dev:worker": "pnpm --filter @bhojflow/api worker",
    "dev:dashboard": "pnpm --filter @bhojflow/dashboard dev",
    "dev:customer": "pnpm --filter @bhojflow/customer dev",
    "dev:kds": "pnpm --filter @bhojflow/kds dev",
    "dev": "pnpm run --parallel --filter @bhojflow/api --filter @bhojflow/dashboard --filter @bhojflow/customer --filter @bhojflow/kds dev",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint",
    "db:push": "pnpm --filter @bhojflow/prisma db:push",
    "db:generate": "pnpm --filter @bhojflow/prisma db:generate",
    "db:migrate": "pnpm --filter @bhojflow/prisma db:migrate",
    "db:seed": "pnpm --filter @bhojflow/prisma db:seed",
    "db:setup": "pnpm db:push && pnpm db:generate && pnpm db:seed",
    "db:check": "node scripts/check-db-connection.cjs",
    "load:burst": "node scripts/load/burst-orders.mjs",
    "load:menu": "node scripts/load/public-menu-load.test.js",
    "load:orders": "node scripts/load/order-create-load.test.js",
    "load:customer-flow": "node scripts/load/full-customer-flow-load.test.js",
    "load:dashboard-sockets": "node scripts/load/dashboard-socket-load.test.js",
    "load:kds-sockets": "node scripts/load/kds-socket-load.test.js",
    "load:auth-onboarding": "node scripts/load/auth-onboarding-load.test.js",
    "load:friday": "node scripts/load/friday-peak-scenario.test.js",
    "load:redis": "node scripts/load/redis-failure-watch.mjs",
    "load:reconnect": "node scripts/load/socket-reconnect-storm.mjs",
    "redis:ping": "powershell -ExecutionPolicy Bypass -File scripts/redis-cli.ps1 PING",
    "redis:info": "powershell -ExecutionPolicy Bypass -File scripts/redis-cli.ps1 INFO",
    "redis:latency": "powershell -ExecutionPolicy Bypass -File scripts/redis-cli.ps1 LATENCY",
    "docker:up": "cd infrastructure/docker && docker-compose up -d",
    "docker:down": "cd infrastructure/docker && docker-compose down"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  }
}
