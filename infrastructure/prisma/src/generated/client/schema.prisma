// schema.prisma - DineFlow V2 Complete Schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── TENANTS (Businesses) ──────────────────────────────────
model Tenant {
  id             String    @id @default(cuid())
  slug           String    @unique // "rustic-bistro" → dineflow.com/order/rustic-bistro
  businessName   String
  description    String?
  logoUrl        String?
  coverImageUrl  String?
  primaryColor   String    @default("#FF6B35")
  accentColor    String    @default("#2D3748")
  cuisineType    String?
  businessType   String    @default("restaurant") // restaurant|cafe|hotel|street_vendor|cloud_kitchen
  address        String?
  city           String?
  phone          String?
  email          String
  website        String?
  instagramUrl   String?
  currency       String    @default("INR")
  currencySymbol String    @default("₹")
  taxRate        Float     @default(5.0) // GST percentage
  timezone       String    @default("Asia/Kolkata")
  isActive       Boolean   @default(true)
  plan           Plan      @default(FREE)
  planStartedAt  DateTime?
  planExpiresAt  DateTime?
  trialEndsAt    DateTime? // 1-month free trial
  businessHours  Json? // { monday: { open: "09:00", close: "22:00", isOpen: true }, ... }
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isPilot        Boolean   @default(false)

  // Relations
  users          User[]
  categories     Category[]
  menuItems      MenuItem[]
  tables         Table[]
  zones          Zone[]
  orders         Order[]
  diningSessions DiningSession[]
  offers         Offer[]
  reviews        Review[]
  staffInvites   StaffInvite[]
  analytics      DailyAnalytics[]
  bills          Bill[]
  orderAuditLogs OrderAuditLog[]
  gstin          String?
  fssai          String?
}

// ─── USERS (Staff/Owners) ──────────────────────────────────
model User {
  id                 String    @id @default(cuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  email              String    @unique
  employeeCode       String?   @unique
  clerkUserId        String?   @unique
  passwordHash       String
  mustChangePassword Boolean   @default(false)
  securityQuestion   String?
  securityAnswerHash String?
  role               UserRole  @default(WAITER)
  preferredLanguage  String    @default("en")
  avatarUrl          String?
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  serviceReviews Review[]       @relation("ServiceStaffReviews")

  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model StaffInvite {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email      String
  role       UserRole
  token      String    @unique @default(cuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

// ─── MENU ─────────────────────────────────────────────────
model Category {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  emoji       String?  @default("🍽️")
  imageUrl    String?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  availFrom   String? // "09:00" - time-based availability
  availUntil  String? // "23:00"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menuItems MenuItem[]

  @@index([tenantId, sortOrder])
}

model MenuItem {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  price           Float // in paise (₹12.99 stored as 1299) - NO, store as Float for simplicity
  compareAtPrice  Float? // original price for "was ₹X" display
  images          String[] // Cloudinary URLs, first is primary
  isAvailable     Boolean  @default(true)
  isPopular       Boolean  @default(false)
  isChefSpecial   Boolean  @default(false)
  isBestSeller    Boolean  @default(false)
  isNew           Boolean  @default(false)
  isVeg           Boolean? // null = not tagged, true = veg, false = non-veg
  isVegan         Boolean  @default(false)
  isGlutenFree    Boolean  @default(false)
  spiceLevel      Int? // 0=none, 1=mild, 2=medium, 3=hot, 4=extra hot
  allergens       String[] // ["nuts", "dairy", "gluten", "eggs", "soy"]
  calories        Int?
  prepTimeMinutes Int?
  sortOrder       Int      @default(0)
  tags            String[] // flexible tagging
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  modifierGroups ModifierGroup[]
  orderItems     OrderItem[]

  @@index([tenantId, categoryId])
  @@index([tenantId, isAvailable])
}

model ModifierGroup {
  id            String   @id @default(cuid())
  menuItemId    String
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name          String // "Choose Size", "Add Extras", "Select Spice Level"
  isRequired    Boolean  @default(false)
  minSelections Int      @default(0)
  maxSelections Int      @default(1)
  sortOrder     Int      @default(0)

  modifiers Modifier[]
}

model Modifier {
  id              String        @id @default(cuid())
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  name            String // "Large", "Extra Cheese", "Spicy"
  priceAdjustment Float         @default(0) // +50, -20, 0
  isDefault       Boolean       @default(false)
  isAvailable     Boolean       @default(true)
  sortOrder       Int           @default(0)
}

// ─── OFFERS & COMBOS ──────────────────────────────────────
model Offer {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title         String // "Happy Hour 20% Off"
  description   String?
  offerType     OfferType // PERCENTAGE | FIXED | COMBO | BOGO
  discountValue Float? // 20 for 20%, 50 for ₹50 off
  imageUrl      String?
  bannerColor   String?
  menuItemIds   String[] // items this applies to (empty = all items)
  minimumOrder  Float? // minimum cart value to activate
  isActive      Boolean   @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  usageCount    Int       @default(0)
  maxUsage      Int?
  createdAt     DateTime  @default(now())

  @@index([tenantId, isActive])
}

// ─── TABLES & ZONES ───────────────────────────────────────
model Zone {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String // "Main Dining", "Outdoor", "Bar", "Private"
  color     String @default("#3B82F6")
  sortOrder Int    @default(0)

  tables Table[]

  @@index([tenantId])
}

model Table {
  id               String      @id @default(cuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  zoneId           String?
  zone             Zone?       @relation(fields: [zoneId], references: [id])
  name             String // "Table 1", "T-01", "Bar Seat 3"
  capacity         Int         @default(4)
  seats            Int         @default(4)
  occupiedSeats    String[]    @default([])
  shape            TableShape  @default(SQUARE)
  status           TableStatus @default(AVAILABLE)
  positionX        Float       @default(0) // for floor plan canvas
  positionY        Float       @default(0)
  qrCodeUrl        String? // stored QR image URL
  qrSecret         String      @unique @default(cuid()) // used to validate QR scan
  currentOrderId   String? // FK to active Order (for quick lookup)
  currentSessionId String? // FK to active DiningSession
  isRoaming        Boolean     @default(false) // street vendor roaming table
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  orders         Order[]
  diningSessions DiningSession[]

  @@index([tenantId, status])
}

// ─── CUSTOMER SESSIONS ────────────────────────────────────
// ─── CUSTOMERS (Lightweight, for login + history) ─────────
model Customer {
  id            String    @id @default(cuid())
  phone         String    @unique
  name          String?
  email         String?
  isActive      Boolean   @default(true)
  deactivatedAt DateTime?
  anonymizedAt  DateTime?
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())

  sessions DiningSession[]
  reviews  Review[]

  @@index([isActive])
}

// ─── DINING SESSIONS (Open Tab / Check) ───────────────────
model DiningSession {
  id               String        @id @default(cuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tableId          String?
  table            Table?        @relation(fields: [tableId], references: [id])
  customerId       String
  customer         Customer      @relation(fields: [customerId], references: [id])
  partySize        Int           @default(1)
  sessionStatus    SessionStatus @default(OPEN)
  source           String        @default("qr")
  openedAt         DateTime      @default(now())
  closedAt         DateTime?
  isBillGenerated  Boolean       @default(false)
  billGeneratedAt  DateTime?
  attendedByUserId String?
  attendedByName   String?

  orders Order[]
  bill   Bill?
  review Review?

  @@index([tenantId, sessionStatus, tableId])
  @@index([tenantId, tableId, openedAt])
  @@index([tenantId, tableId, sessionStatus, openedAt])
  @@index([tenantId, source])
  @@index([tableId])
  @@index([customerId])
}

// ─── BILLS (Generated after session completion) ───────────
model Bill {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId String        @unique
  session   DiningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  invoiceNumber String? @unique

  subtotal       Float
  taxAmount      Float @default(0)
  discountAmount Float @default(0)
  totalAmount    Float

  paymentStatus String    @default("UNPAID") // UNPAID | PAID | PARTIAL
  paymentMethod String? // cash | upi | card
  paidAt        DateTime?
  generatedAt   DateTime  @default(now())

  // Snapshots
  businessName    String?
  businessAddress String?
  gstin           String?
  fssai           String?

  @@index([tenantId])
  @@index([sessionId])
}

// ─── ORDERS ───────────────────────────────────────────────
model Order {
  id              String         @id @default(cuid())
  version         Int            @default(0)
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tableId         String?
  table           Table?         @relation(fields: [tableId], references: [id])
  diningSessionId String?
  diningSession   DiningSession? @relation(fields: [diningSessionId], references: [id])
  orderNumber     String // human-readable: "#SN7N3KJN" - unique per tenant
  orderType       OrderType      @default(DINE_IN) // DINE_IN | TAKEAWAY | ROAMING
  status          OrderStatus    @default(NEW)
  placedBy        String         @default("customer") // customer | vendor

  // Pricing
  subtotal       Float // sum of items before tax
  taxAmount      Float @default(0)
  discountAmount Float @default(0)
  totalAmount    Float // final amount

  // Customer info (captured at order time)
  customerName  String?
  customerPhone String?

  specialInstructions String?
  estimatedPrepMins   Int? // set by kitchen
  acceptedAt          DateTime?
  preparingAt         DateTime?
  readyAt             DateTime?
  servedAt            DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?

  // Payment (legacy, bills handle this now for sessions)
  // Fields removed: isPaid, paymentMethod, paymentReference

  // Rating
  hasReview Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     OrderItem[]
  review    Review?
  auditLogs OrderAuditLog[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, tableId, status])
  @@index([tenantId, diningSessionId, status, createdAt])
  @@index([tenantId, orderNumber])
  @@index([diningSessionId])
  @@index([diningSessionId, createdAt])
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String? // nullable in case item is deleted after order
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])

  // Snapshot at time of order (in case menu changes later)
  name              String
  description       String?
  imageUrl          String? // snapshot of primary image
  unitPrice         Float
  quantity          Int
  totalPrice        Float // unitPrice * quantity + modifiers
  selectedModifiers Json // [{ groupName: "Size", modifierName: "Large", priceAdj: 50 }]
  specialNote       String?
  isVeg             Boolean?

  createdAt DateTime @default(now())

  @@index([orderId])
}

// ─── REVIEWS ──────────────────────────────────────────────
model Review {
  id                 String         @id @default(cuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId            String?        @unique
  order              Order?         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  diningSessionId    String?        @unique
  diningSession      DiningSession? @relation(fields: [diningSessionId], references: [id])
  customerId         String?
  customer           Customer?      @relation(fields: [customerId], references: [id])
  serviceStaffUserId String?
  serviceStaff       User?          @relation("ServiceStaffReviews", fields: [serviceStaffUserId], references: [id])

  overallRating    Int // 1-5 stars
  foodRating       Int? // 1-5
  serviceRating    Int? // 1-5
  comment          String? // "Leave a note for the chef"
  tipAmount        Float   @default(0)
  serviceStaffName String?
  isPublic         Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([orderId])
  @@index([diningSessionId])
  @@index([serviceStaffUserId])
}

// ─── ANALYTICS (Daily Snapshots) ──────────────────────────
model DailyAnalytics {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date     DateTime // date only (midnight UTC)

  totalOrders     Int     @default(0)
  completedOrders Int     @default(0)
  cancelledOrders Int     @default(0)
  totalRevenue    Float   @default(0)
  totalTax        Float   @default(0)
  avgOrderValue   Float   @default(0)
  avgPrepTimeMins Float   @default(0)
  uniqueCustomers Int     @default(0)
  peakHour        Int? // 0-23
  topItemId       String?
  topItemName     String?
  topItemRevenue  Float   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date])
  @@index([tenantId, date])
}

// ─── ENUMS ────────────────────────────────────────────────
enum Plan {
  FREE
  STARTER // ₹499/mo
  GOLD // ₹999/mo
  PLATINUM // ₹1599/mo
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
}

enum TableShape {
  ROUND
  SQUARE
  RECTANGLE
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  ORDERING_OPEN
  KITCHEN_ACTIVE
  AWAITING_BILL
  PAYMENT_PENDING
  CLEANING
}

enum SessionStatus {
  OPEN
  PARTIALLY_SENT
  ACTIVE
  AWAITING_BILL
  CLOSED
  CANCELLED
}

enum OrderStatus {
  NEW
  ACCEPTED
  PREPARING
  READY
  SERVED
  RECEIVED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  ROAMING
}

enum OfferType {
  PERCENTAGE
  FIXED
  COMBO
  BOGO
}

enum AuditActorType {
  USER
  CUSTOMER
  SYSTEM
}

model OrderAuditLog {
  id             String         @id @default(cuid())
  tenantId       String
  orderId        String
  actorType      AuditActorType
  actorId        String?
  deviceId       String?
  previousStatus OrderStatus?
  newStatus      OrderStatus
  reasonCode     String?
  metadata       Json?
  createdAt      DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt(sort: Desc)])
  @@index([tenantId, actorId, createdAt])
  @@index([tenantId, newStatus, createdAt])
  @@index([actorType, createdAt])
}
